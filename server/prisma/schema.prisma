// Mundo dos Brinquedos — data model
// Prototype: SQLite (zero setup). Portable to Neon Postgres later:
// statuses are Strings (not enums), money is Int centavos, images/variants are
// relations — so switching `provider` to "postgresql" + migrate is clean.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Neon pooled (runtime)
  directUrl = env("DIRECT_URL") // Neon direct (migrations / db push)
}

model Category {
  id        Int        @id @default(autoincrement())
  slug      String     @unique
  name      String
  nameEn    String     @default("")
  emoji     String     @default("🧸")
  accent    String     @default("brand") // token: brand|sun|sky|mint|grape
  blurb     String     @default("")
  blurbEn   String     @default("")
  parentId  Int?
  parent    Category?  @relation("Sub", fields: [parentId], references: [id])
  children  Category[] @relation("Sub")
  sortOrder Int        @default(0)
  active    Boolean    @default(true)
  products  Product[]
  createdAt DateTime   @default(now())
}

model Product {
  id              Int              @id @default(autoincrement())
  slug            String           @unique
  name            String
  nameEn          String           @default("")
  brand           String           @default("")
  sku             String           @default("")
  description     String           @default("")
  descriptionEn   String           @default("")
  categoryId      Int?
  category        Category?        @relation(fields: [categoryId], references: [id])
  priceCents      Int // tier 1 — regular retail price (centavos)
  oldPriceCents   Int? // previous price → shows discount %
  costCents       Int              @default(0)
  price10Cents    Int? // tier 2 — price when the whole cart has 10+ items
  wholesaleCents  Int? // tier 3 — price when the cart reaches the wholesale-value threshold
  pixPercent      Int              @default(5) // Pix discount %
  stock           Int              @default(0)
  lowStockAt      Int              @default(5)
  minWholesaleQty Int              @default(0)
  packQty         Int              @default(1) // units per box/package
  installmentsMax Int              @default(12)
  ageGroup        String           @default("")
  material        String           @default("")
  weightGrams     Int              @default(0)
  warranty        String           @default("")
  featured        Boolean          @default(false)
  isNew           Boolean          @default(false)
  bestSeller      Boolean          @default(false)
  wholesaleOnly   Boolean          @default(false)
  active          Boolean          @default(true)
  images          ProductImage[]
  variants        ProductVariant[]
  reviews         Review[]
  orderItems      OrderItem[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  // Prototype placeholders use "emoji:🧸|grad:brand"; real photos use a URL.
  url       String
  alt       String  @default("")
  sortOrder Int     @default(0)
}

model ProductVariant {
  id              Int     @id @default(autoincrement())
  productId       Int
  product         Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  kind            String // "cor" | "tamanho"
  label           String // "Rosa" | "Aro 16"
  swatch          String  @default("") // hex for colour swatches
  stock           Int     @default(0)
  priceDeltaCents Int     @default(0)
}

model Customer {
  id              Int      @id @default(autoincrement())
  name            String
  email           String   @unique
  phone           String   @default("")
  cpfCnpj         String   @default("")
  kind            String   @default("varejo") // varejo | atacado
  wholesaleStatus String   @default("none") // none | pending | approved | rejected
  businessName    String   @default("")
  city            String   @default("")
  state           String   @default("")
  notes           String   @default("")
  createdAt       DateTime @default(now())
  orders          Order[]
}

model Order {
  id            Int         @id @default(autoincrement())
  code          String      @unique // MDB-2026-0001
  customerId    Int?
  customer      Customer?   @relation(fields: [customerId], references: [id])
  customerName  String
  customerPhone String      @default("")
  customerEmail String      @default("")
  kind          String      @default("varejo") // varejo | atacado
  status        String      @default("recebido")
  // recebido|aguardando_pagamento|pago|em_separacao|embalado|enviado|saiu_entrega|entregue|cancelado|reembolsado
  paymentMethod String      @default("pix") // pix | cartao | boleto
  paymentStatus String      @default("pendente") // pendente | pago | falhou | reembolsado
  subtotalCents Int
  discountCents Int         @default(0)
  shippingCents Int         @default(0)
  totalCents    Int
  cep           String      @default("")
  address       String      @default("")
  city          String      @default("")
  state         String      @default("")
  trackingCode  String      @default("")
  note          String      @default("")
  items         OrderItem[]
  createdAt     DateTime    @default(now())
}

model OrderItem {
  id         Int      @id @default(autoincrement())
  orderId    Int
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  Int?
  product    Product? @relation(fields: [productId], references: [id])
  name       String
  variant    String   @default("")
  priceCents Int
  qty        Int
}

model Review {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  author    String
  rating    Int // 1..5
  comment   String   @default("")
  verified  Boolean  @default(true)
  approved  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Banner {
  id         Int      @id @default(autoincrement())
  title      String
  titleEn    String   @default("")
  subtitle   String   @default("")
  subtitleEn String   @default("")
  badge      String   @default("")
  badgeEn    String   @default("")
  ctaLabel   String   @default("")
  ctaLabelEn String   @default("")
  ctaHref    String   @default("")
  cta2Label  String   @default("")
  cta2LabelEn String  @default("")
  cta2Href   String   @default("")
  bg        String   @default("brand") // gradient token
  emoji     String   @default("🧸")
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Editable store info & homepage config — key/value so admin controls copy,
// WhatsApp, hours, wholesale rules, free-shipping threshold, etc.
model Setting {
  key   String @id
  value String
}
